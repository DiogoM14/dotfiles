{
  // ============================================================================
  // UI LAYOUT & PANELS
  // ============================================================================
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    }
  },
  "colorize_brackets": true,
  "theme_overrides": {
    "Tomorrow Night Blue": {
      "accents": ["#ff69b4", "#86C04D", "#ff1493", "#00ffff", "#ff8c00", "#9400d3"],
    },
  },
  "toolbar": {
    "code_actions": false,
  },
  "outline_panel": {
    "git_status": true,
    "file_icons": true,
    "button": true,
  },
  "project_panel": {
    "hide_root": true,
    "auto_reveal_entries": true,
    "indent_size": 18.0,
    "git_status": true,
    "folder_icons": true,
    "entry_spacing": "comfortable",
    "hide_gitignore": false,
    "dock": "right",
  },
  "centered_layout": {
    "left_padding": 0.20000004768371582,
  },
  "bottom_dock_layout": "contained",
  "use_system_window_tabs": true,
  // ============================================================================
  // TABS & TAB BAR
  // ============================================================================
  "tabs": {
    "file_icons": true,
    "git_status": true,
  },
  "tab_bar": {
    "show": true,
  },
  "preview_tabs": {
    "enable_preview_from_file_finder": false,
  },
  // ============================================================================
  // TITLE BAR
  // ============================================================================
  "title_bar": {
    "show_menus": false,
    "show_sign_in": false,
    "show_branch_name": true,
    "show_branch_icon": true,
  },
  // ============================================================================
  // THEME & APPEARANCE
  // ============================================================================
  "theme": "Catppuccin Macchiato",
  "icon_theme": "Colored Zed Icons Theme Dark",
  "cursor_shape": "underline",
  "cursor_blink": true,
  // ============================================================================
  // FONTS & FONT SIZES
  // ============================================================================
  "buffer_font_family": "JetBrains Mono",
  "ui_font_family": ".SystemUIFont",
  "buffer_font_size": 15,
  "ui_font_size": 15,
  "agent_buffer_font_size": 12.0,
  "agent_ui_font_size": 15.0,
  // ============================================================================
  // EDITOR BEHAVIOR
  // ============================================================================
  "preferred_line_length": 100,
  "buffer_line_height": "comfortable",
  "autosave": "on_window_change",
  "vim_mode": false,
  "confirm_quit": false,
  "hover_popover_enabled": true,
  // ============================================================================
  // CODE FORMATTING & ACTIONS
  // ============================================================================
  "code_actions_on_format": {
    "source.fixAll.eslint": true,
  },
  "prettier": {
    "allowed": true,
  },
  // ============================================================================
  // INLAY HINTS
  // ============================================================================
  "inlay_hints": {
    "enabled": true,
    "show_background": true,
    "show_value_hints": true,
    "show_other_hints": true,
    "show_parameter_hints": false,
    "show_type_hints": false,
  },
  // ============================================================================
  // AI & EDITING FEATURES
  // ============================================================================
  "show_edit_predictions": true,
  "edit_predictions": {
    "mode": "subtle",
  },
  "features": {
    "edit_prediction_provider": "zed",
  },
  // ============================================================================
  // TELEMETRY
  // ============================================================================
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  // ============================================================================
  // LANGUAGE SERVER PROTOCOL (LSP)
  // ============================================================================
  "lsp": {
    "typescript-language-server": {
      "initialization_options": {
        "preferences": {
          "includeInlayParameterNameHints": "all",
          "includeInlayParameterNameHintsWhenArgumentMatchesName": false,
          "includeInlayFunctionParameterTypeHints": false,
          "includeInlayVariableTypeHints": false,
          "includeInlayVariableTypeHintsWhenTypeMatchesName": false,
          "includeInlayPropertyDeclarationTypeHints": false,
          "includeInlayFunctionLikeReturnTypeHints": false,
          "includeInlayEnumMemberValueHints": false,
        },
      },
    },
  },
  // ============================================================================
  // LANGUAGE-SPECIFIC SETTINGS
  // ============================================================================
  "languages": {
    "TypeScript": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "npx",
          "arguments": [
            "prettier",
            "--stdin-filepath",
            "{buffer_path}",
            "--print-width",
            "120",
            "--tab-width",
            "4",
            "--use-tabs",
            "false",
            "--semi",
            "true",
            "--single-quote",
            "false",
            "--trailing-comma",
            "all",
            "--bracket-spacing",
            "true",
            "--arrow-parens",
            "always",
          ],
        },
      },
    },
    "JavaScript": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "npx",
          "arguments": [
            "prettier",
            "--stdin-filepath",
            "{buffer_path}",
            "--print-width",
            "120",
            "--tab-width",
            "4",
            "--use-tabs",
            "false",
            "--semi",
            "true",
            "--single-quote",
            "false",
            "--trailing-comma",
            "all",
            "--bracket-spacing",
            "true",
            "--arrow-parens",
            "always",
          ],
        },
      },
    },
    "HTML": {
      "language_servers": ["angular", "..."],
      "format_on_save": "on",
    },
    "SCSS": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "npx",
          "arguments": [
            "prettier",
            "--stdin-filepath",
            "{buffer_path}",
            "--print-width",
            "120",
            "--tab-width",
            "4",
          ],
        },
      },
    },
  },
  // ============================================================================
  // LANGUAGE MODELS & AI
  // ============================================================================
  "language_models": {
    "openai_compatible": {
      "ITO GPT": {
        "api_url": "http://localhost:8787/v1",
        "available_models": [
          {
            "name": "sonnet",
            "display_name": "ITO GPT",
            "max_tokens": 200000,
          },
        ],
      },
    },
  },
  "agent": {
    "default_profile": "ask",
    "default_model": {
      "provider": "ITO GPT",
      "model": "sonnet",
    },
  },
}
